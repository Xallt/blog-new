---
import { Image } from "astro:assets";
import mePhoto from "../../assets/img/me.jpg";
import Nav from "../../components/Nav.astro";
import * as aboutContent from "../../content/about.mdx";
import { navItems } from "../../data/home";
import BaseLayout from "../../layouts/BaseLayout.astro";

const { Content } = aboutContent;
---

<BaseLayout title="Dmitry Shabat — About">
	<div class="page post-content">
		<Nav items={navItems} />
		<article class="about-prose" lang="en">
			<header class="about-header">
				<h1 class="about-title">About</h1>
			</header>
			<Image
				src={mePhoto}
				alt="Dmitry Shabat"
				class="about-portrait"
				width={200}
				loading="eager"
			/>
			<Content />
		</article>
	</div>
</BaseLayout>

<style>
	.post-content {
		font-size: 1.3rem;
		font-weight: 400;
	}

	.about-prose {
		max-width: 65ch;
		margin-inline: auto;
	}

	.about-header {
		margin-bottom: var(--space-md);
		text-align: center;
	}

	.about-title {
		margin: 0;
		font-size: 2.5rem;
		font-weight: 400;
		color: var(--heading-color);
		font-family: var(--font-family-heading);
	}

	.about-prose :global(img.about-portrait) {
		float: right;
		width: 200px;
		height: auto;
		max-width: min(200px, 46%);
		margin: 0 0 var(--space-sm) var(--space-md);
		border-radius: 4px;
	}

	.about-prose::after {
		content: "";
		display: table;
		clear: both;
	}

	.about-prose ul {
		padding-left: 1.25rem;
		margin: 0 0 var(--space-md);
	}

	.about-prose li {
		margin-bottom: var(--space-sm);
	}

	@media (max-width: 520px) {
		.about-prose :global(img.about-portrait) {
			float: none;
			display: block;
			max-width: 200px;
			margin: 0 auto var(--space-md);
		}
	}
</style>
