---
import Nav from "../../components/Nav.astro";
import PostList from "../../components/PostList.astro";
import { getAllPosts, navItems, parsePost, type Post } from "../../data/home";
import BaseLayout from "../../layouts/BaseLayout.astro";

const allPosts = await getAllPosts();

const posts: Post[] = [...allPosts]
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
	.map((entry) => parsePost(entry));
---

<BaseLayout title="Dmitry Shabat — Posts">
	<div class="page">
		<Nav items={navItems} />
		<section class="section" aria-labelledby="posts-heading">
			<h2 id="posts-heading" class="posts-section-title">Posts</h2>
			<PostList posts={posts} />
		</section>
	</div>
</BaseLayout>

<style>
	.section {
		margin-bottom: var(--space-xl);
	}
</style>
