---
import { getCollection } from "astro:content";
import Hero from "../components/Hero.astro";
import Nav from "../components/Nav.astro";
import PostList from "../components/PostList.astro";
import StuffGrid from "../components/StuffGrid.astro";
import { hero, navItems, parsePost, stuff, type Post } from "../data/home";
import BaseLayout from "../layouts/BaseLayout.astro";

const allPosts = await getCollection("posts");

const recentPosts: Post[] = [...allPosts]
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
	.slice(0, 3)
	.map((entry) => parsePost(entry));
---

<BaseLayout title="Dmitry Shabat — Home">
	<div class="page">
		<Nav items={navItems} />
		<Hero hero={hero} />
		<PostList posts={recentPosts} />
		<StuffGrid stuff={stuff} />
	</div>
</BaseLayout>
