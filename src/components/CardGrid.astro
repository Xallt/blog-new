---
import type { Card } from "../data/home";

interface Props {
	cards: Card[];
}

const { cards } = Astro.props;
---

<section class="section" aria-labelledby="cards-heading">
	<h2 id="cards-heading" class="visually-hidden">Stuff</h2>
	<div class="card-grid">
		{
			cards.map((card) => (
				<article class="card">
					<div class={`card-media card-media--${card.media.kind}`}>
						{card.media.kind === "squiggle" && (
							<svg viewBox="0 0 120 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
								<path
									d="M4 28 Q 20 8 38 26 T 72 22 T 108 30"
									fill="none"
									stroke="var(--text-color)"
									stroke-width="1.8"
									stroke-linecap="round"
								/>
								<path
									d="M8 38 Q 28 18 52 34 T 96 26 T 116 36"
									fill="none"
									stroke="var(--border-color)"
									stroke-width="1.2"
									stroke-linecap="round"
								/>
							</svg>
						)}
						{card.media.kind === "text" && <span>{card.media.text}</span>}
						{card.media.kind === "avatar" && (
							<div class="avatar-ring" aria-hidden="true">
								<svg viewBox="0 0 80 80" class="avatar-svg" xmlns="http://www.w3.org/2000/svg">
									<circle
										cx="40"
										cy="40"
										r="36"
										fill="none"
										stroke="var(--text-color)"
										stroke-width="2.5"
									/>
									<circle cx="30" cy="32" r="3" fill="var(--text-color)" />
									<circle cx="50" cy="32" r="3" fill="var(--text-color)" />
									<path
										d="M 28 48 Q 40 58 52 48"
										fill="none"
										stroke="var(--text-color)"
										stroke-width="2.5"
										stroke-linecap="round"
									/>
								</svg>
							</div>
						)}
					</div>
					<h3 class="card-title">{card.title}</h3>
					<p class="card-excerpt">{card.excerpt}</p>
				</article>
			))
		}
	</div>
</section>

<style>
	.section {
		margin-bottom: var(--space-xl);
	}

	.card-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--space-md);
	}

	@media (max-width: 960px) {
		.card-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 520px) {
		.card-grid {
			grid-template-columns: 1fr;
		}
	}

	.card {
		border: 1px solid var(--border-color);
		border-radius: 4px;
		padding: var(--space-sm);
		background: var(--surface-color);
		display: flex;
		flex-direction: column;
		min-height: 8rem;
	}

	.card-media {
		min-height: 3.5rem;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: var(--space-sm);
		font-family: var(--font-family-base);
		font-size: 0.7rem;
		text-align: center;
		color: var(--text-muted-color);
	}

	.card-media--squiggle svg {
		width: 100%;
		height: 3rem;
	}

	.card-media--avatar .avatar-ring {
		width: 3.5rem;
		height: 3.5rem;
	}

	.card-title {
		margin: 0 0 var(--space-xs);
		font-size: 1rem;
		font-weight: 400;
	}

	.card-excerpt {
		margin: 0;
		font-family: var(--font-family-base);
		font-size: 0.55rem;
		line-height: 1.4;
		color: var(--text-muted-color);
	}
</style>
