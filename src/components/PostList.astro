---
import type { Post } from "../data/home";
import PostCard from "./PostCard.astro";
interface Props {
	posts: Post[];
}

const { posts } = Astro.props;
---

<section class="section" aria-labelledby="posts-heading">
	<h2 id="posts-heading" class="visually-hidden">Recent posts</h2>
	<div class="post-list">
		{posts.map((post) => <PostCard post={post} />)}
	</div>
</section>

<style>
	.section {
		margin-bottom: var(--space-xl);
	}

	.post-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
	}
</style>
