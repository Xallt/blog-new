---
import type { Post } from "../data/home";

interface Props {
	posts: Post[];
	readMoreHref?: string;
	readMoreLabel?: string;
}

const {
	posts,
	readMoreHref = "/posts",
	readMoreLabel = "Read more",
} = Astro.props;
---

<section class="section" aria-labelledby="posts-heading">
	<h2 id="posts-heading" class="visually-hidden">Recent posts</h2>
	<div class="post-list">
		{
			posts.map((post) => (
				<article class="post-row">
					<div class="post-main">
						<h3 class="post-title">{post.title}</h3>
						{post.tags.length > 0 && (
							<ul class="post-tags">
								{post.tags.map((tag) => (
									<li>{tag}</li>
								))}
							</ul>
						)}
					</div>
					<div class="post-meta">
						<span class="category">{post.category}</span>
						<time>{post.date}</time>
					</div>
				</article>
			))
		}
	</div>
	<p class="read-more-wrap">
		<a href={readMoreHref}>{readMoreLabel}</a>
	</p>
</section>
