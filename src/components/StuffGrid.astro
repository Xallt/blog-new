---
import type { Stuff } from "../data/home";
import StuffCard from "./StuffCard.astro";

interface Props {
	stuff: Stuff[];
}

const { stuff } = Astro.props;
---

<div class="stuff-grid">
	{stuff.map((item) => <StuffCard stuff={item} />)}
</div>

<style>
	.stuff-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-md);
	}

	@media (max-width: 960px) {
		.stuff-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 520px) {
		.stuff-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<style is:global>
	.stuff-section-title {
		font-family: var(--font-family-heading);
		font-size: clamp(1.75rem, 4vw, 2.35rem);
		font-weight: 400;
		line-height: 1.15;
		margin: 0 0 var(--space-md);
		text-align: center;
		color: var(--heading-color);
	}
</style>
