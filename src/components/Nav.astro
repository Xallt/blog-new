---
import type { NavItem } from "../data/home";

interface Props {
	items: NavItem[];
}

const { items } = Astro.props;

function normalizePath(p: string): string {
	if (p.length > 1 && p.endsWith("/")) {
		return p.slice(0, -1);
	}
	return p;
}

const baseRoot = normalizePath(import.meta.env.BASE_URL);

function isNavActive(href: string, pathname: string): boolean {
	const path = normalizePath(pathname);
	const target = normalizePath(href);
	// Root of the app (/ or base URL like /blog-new) — exact match only
	if (target === "/" || target === "" || target === baseRoot) {
		return path === target;
	}
	return path === target || path.startsWith(`${target}/`);
}

const pathname = Astro.url.pathname;
---

<nav class="nav" aria-label="Primary">
	{
		items.map((item) => {
			const active = isNavActive(item.href, pathname);
			return (
				<a
					class:list={["bracketed", { "nav-link-active": active }]}
					href={item.href}
					aria-current={active ? "page" : undefined}
				>
					{item.label}
				</a>
			);
		})
	}
</nav>

<style>
	.nav {
		font-family: var(--font-family-base);
		font-size: 1rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: var(--space-sm) var(--space-md);
		margin-bottom: var(--space-sm);
	}

	.nav a {
		text-decoration: none;
	}

	.nav a:hover {
		text-decoration: underline;
	}

	.nav a.nav-link-active {
		color: color-mix(in srgb, var(--link-color) 80%, rgb(255 255 255) 20%);
		font-weight: 600;
		text-decoration: none;
	}

	.bracketed.nav-link-active::before,
	.bracketed.nav-link-active::after {
		opacity: 1;
	}

	.bracketed::before {
		content: "<";
		opacity: 0.85;
	}

	.bracketed::after {
		content: ">";
		opacity: 0.85;
	}
</style>
